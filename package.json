{
  "name": "momentune-algorithm",
  "version": "0.1.0",
  "description": "Momentune 图片→音乐情绪匹配算法模块",
  "private": true,
  "type": "module",
  "main": "./src/algorithm/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
